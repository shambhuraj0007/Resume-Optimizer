{
    "name": "ShortlistAI Assistant",
    "version": "1.3",
    "manifest_version": 3,
    "description": "Analyze Job Descriptions instantly with ShortlistAI.",
    "permissions": [
        "sidePanel",
        "contextMenus",
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://*.shortlistai.cv/*",
        "*://*.shortlistai.cv/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_title": "Open ShortlistAI",
        "default_icon": {
            "32": "icon32.png",
            "128": "icon128.png"
        }
    },
    "icons": {
        "32": "icon32.png",
        "128": "icon128.png"
    }
}